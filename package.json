{
  "name": "portofoliomkl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run check:contrast && npm run check:skills && next build --turbopack",
    "start": "node .next/standalone/server.js",
    "check:contrast": "tsx scripts/check-contrast.ts",
    "check:skills": "tsx scripts/check-skills.ts",
    "test:e2e": "playwright test",
    "e2e:server": "node .next/standalone/server.js",
    "e2e:prepare": "npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && cp -r messages .next/standalone/messages"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.546.0",
    "next": "15.5.5",
    "next-intl": "^4.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
